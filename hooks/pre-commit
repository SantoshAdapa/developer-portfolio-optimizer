#!/bin/sh
# Pre-commit hook: runs the same lint checks as CI
# Prevents commits that would fail the "Lint & Type Check (Backend)" job
#
# Setup: from the repo root, run:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

echo "Running pre-commit checks..."

# Check if ruff is available
if ! command -v ruff >/dev/null 2>&1; then
    echo "WARNING: ruff not installed. Skipping lint checks."
    echo "Install with: pip install ruff"
    exit 0
fi

cd backend || exit 0

# 1. Ruff lint
echo "  [1/3] ruff check..."
if ! ruff check . 2>&1; then
    echo ""
    echo "COMMIT BLOCKED: ruff lint errors found."
    echo "Fix with: cd backend && ruff check --fix ."
    exit 1
fi

# 2. Ruff format
echo "  [2/3] ruff format --check..."
if ! ruff format --check . 2>&1; then
    echo ""
    echo "COMMIT BLOCKED: formatting issues found."
    echo "Fix with: cd backend && ruff format ."
    exit 1
fi

# 3. Mypy (optional - don't block on it if not installed)
if command -v mypy >/dev/null 2>&1; then
    echo "  [3/3] mypy type check..."
    if ! mypy app/ --ignore-missing-imports 2>&1; then
        echo ""
        echo "COMMIT BLOCKED: type errors found."
        exit 1
    fi
else
    echo "  [3/3] mypy not installed, skipping type check."
fi

echo "All pre-commit checks passed!"
